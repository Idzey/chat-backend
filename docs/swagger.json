  "info": {
    "title": "Chat Backend API",
    "description": "REST API documentation for the Chat application",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "users",
      "description": "User profile management"
    },
    {
      "name": "chats",
      "description": "Chat room management"
    },
    {
      "name": "messages",
      "description": "Chat message operations"
    },
    {
      "name": "files",
      "description": "File upload & storage"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "username": {
            "type": "string",
            "example": "johndoe"
          }
        }
      },
      "CompleteUserDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "example": "John",
            "description": "First name"
          },
          "lastName": {
            "type": "string",
            "example": "Doe",
            "description": "Last name"
          }
        },
        "required": [
          "firstName",
          "lastName"
        ]
      },
      "DeviceTypeDto": {
        "type": "object",
        "properties": {
          "deviceType": {
            "type": "string",
            "enum": [
              "MOBILE",
              "WEB"
            ],
            "example": "WEB",
            "description": "Client device type"
          }
        },
        "required": [
          "deviceType"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "P@ssword123",
            "description": "Password (8-20 characters)",
            "minLength": 8,
            "maxLength": 20
          },
          "name": {
            "type": "string",
            "example": "John Doe",
            "description": "Display name (2-50 characters)",
            "minLength": 2,
            "maxLength": 50
          }
        },
        "required": [
          "email",
          "password",
          "name"
        ]
      },
      "CreateChatDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "General",
            "description": "Chat name"
          },
          "participantIds": {
            "example": [
              "userId1",
              "userId2"
            ],
            "description": "Initial participant IDs",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "UpdateChatDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "New Name",
            "description": "New chat name"
          }
        }
      },
      "AddUserToChatDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "clxxxxxxxxxxxxx",
            "description": "ID of the user to add"
          }
        },
        "required": [
          "userId"
        ]
      },
      "GetOrCreateChatDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "clxxxxxxxxxxxxx",
            "description": "Target user ID for private chat"
          }
        },
        "required": [
          "userId"
        ]
      }
    }
  }
}